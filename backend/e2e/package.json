{
  "name": "contract-kit-v17-e2e-tests",
  "version": "1.0.0",
  "description": "End-to-end Playwright tests for Contract Kit V17 WebUI",
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:autofill": "playwright test test_webui_autofill.spec.ts",
    "playwright:install": "playwright install",
    "playwright:install-deps": "playwright install-deps",
    "report": "playwright show-report test-results/playwright-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@types/node": "^20.10.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
