# =============================================================================
# KiloCode Ecosystem — Environment Variables
# Copy: cp deploy/.env.example /opt/kilocode/.env
# NEVER commit .env to version control.
# =============================================================================

# ── Service Ports (canonical) ─────────────────────────────────────────────
RUNTIME_PORT=
SETTINGS_PORT=
HERMES_PORT=
WEBUI_PORT=
NATS_PORT=
OPEN_WEBUI_PORT=
LITELLM_PORT=
OLLAMA_PORT=
LM_STUDIO_PORT=
SHIBA_GATEWAY_PORT=

# ── Core URLs ────────────────────────────────────────────────────────────
RUNTIME_URL=
SETTINGS_URL=
HERMES_URL=
NATS_URL=

# ── LM Studio (local RTX 3090Ti, 700GB GGUF) ─────────────────────────────
LM_STUDIO_URL=
LM_STUDIO_API_KEY=
# LM Studio OpenAI-compatible endpoint: http://localhost:1234/v1

# ── Ollama ────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=

# ── LiteLLM Proxy ────────────────────────────────────────────────────────
LITELLM_BASE_URL=
# If using Tailscale: LITELLM_BASE_URL=http://100.117.190.97:4000/v1

# ── Cloud API Keys — used by ZeroClaw multi-target selector + Kilo Code ──
# Anthropic / OpenAI are read from ENVIRONMENT in Kilo Code Providers tab
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# DeepSeek  — add your key from https://platform.deepseek.com/api-keys
DEEPSEEK_API_KEY=
# Groq      — https://console.groq.com/keys
GROQ_API_KEY=
# MiniMax   — https://www.minimax.io/platform/user-center/basic-information/interface-key
MINIMAX_API_KEY=
# SiliconFlow — https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY=
# OpenRouter  — aggregates 100+ providers + live pricing (used by pricing-service.ts)
OPENROUTER_API_KEY=

# ── WebUI / Agent Token ───────────────────────────────────────────────────
WEBUI_AGENT_TOKEN=
WEBUI_SECRET_KEY=

# ── KiloCode Runtime ─────────────────────────────────────────────────────
KILOCODE_MODE=
LOG_LEVEL=

# ── Open WebUI ────────────────────────────────────────────────────────────
OPEN_WEBUI_SECRET_KEY=

# ── VPS ──────────────────────────────────────────────────────────────────
VPS_HOST=
VPS_USER=
SSH_KEY=

# ── Shiba Memory Gateway ─────────────────────────────────────────────────
SHIBA_URL=
SHIBA_DB_URL=

# ── Hermes Bridge Auth ───────────────────────────────────────────────────
# Used by Kilo Code Providers tab (env: kilo-code.new.hermes.apikey)
# and ZeroClaw when routing tasks through the Hermes pipeline
HERMES_API_KEY=
# MiniMax key is also accepted here as the Hermes default model provider
HERMES_MINIMAX_API_KEY=

# ── OpenClaw Gateway ─────────────────────────────────────────────────────
# Self-hosted AI assistant gateway — no API key needed, but URL must be set
OPENCLAW_URL=http://localhost:18789
# OpenClaw uses your local Ollama/LM Studio models by default.
# For cloud-backed channels, the provider keys above (OPENAI_API_KEY etc.)
# are picked up automatically by OpenClaw from this .env.

# ── ZeroClaw ─────────────────────────────────────────────────────────────
# ZeroClaw reads provider keys directly from this .env — no separate key.
# Enable/disable providers by setting their keys above.
# Local providers (Ollama, LM Studio) need no key — just set the URLs:
# OLLAMA_BASE_URL and LM_STUDIO_URL are already defined above.

# ── Discord (Hermes bots) ─────────────────────────────────────────────────
# DISCORD_TOKEN_HERMES1=<set via setup-windows-env.ps1>
# DISCORD_TOKEN_HERMES2=<set via setup-windows-env.ps1>
# DISCORD_TOKEN_HERMES3=<set via setup-windows-env.ps1>
# DISCORD_TOKEN_HERMES4=<set via setup-windows-env.ps1>
# DISCORD_TOKEN_HERMES5=<set via setup-windows-env.ps1>
# DISCORD_GUILD_ID=<set via setup-windows-env.ps1>
LITELLM_MASTER_KEY=
