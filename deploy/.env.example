# =============================================================================
# KiloCode Ecosystem — Environment Variables (TEMPLATE)
#
# DO NOT put real values in this file. This file is committed to git.
# Real values live in Windows User environment variables.
#
# Setup:
#   1. Run: pwsh scripts\setup-windows-env.ps1
#   2. The script prompts for each key securely (Read-Host -AsSecureString)
#   3. Values are set at User level (no admin), survive reboot, no .env file
#
# This .env.example only documents WHICH variables are read; never their values.
# =============================================================================

# ── Service Ports (canonical) ─────────────────────────────────────────────
RUNTIME_PORT=
SETTINGS_PORT=
HERMES_PORT=
WEBUI_PORT=
NATS_PORT=
OPEN_WEBUI_PORT=
LITELLM_PORT=
OLLAMA_PORT=
LM_STUDIO_PORT=
SHIBA_GATEWAY_PORT=

# ── Core URLs ────────────────────────────────────────────────────────────
RUNTIME_URL=
SETTINGS_URL=
HERMES_URL=
NATS_URL=

# ── LM Studio (local RTX 3090Ti, 700GB GGUF) ─────────────────────────────
LM_STUDIO_URL=
LM_STUDIO_API_KEY=<set via setup-windows-env.ps1>

# ── Ollama ────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=

# ── LiteLLM Proxy ────────────────────────────────────────────────────────
LITELLM_BASE_URL=
LITELLM_MASTER_KEY=<set via setup-windows-env.ps1>

# ── Cloud API Keys (cost-conscious set — Anthropic and OpenAI excluded) ──
# Get keys from:
#   DeepSeek    — https://platform.deepseek.com/api-keys
#   Groq        — https://console.groq.com/keys
#   MiniMax     — https://www.minimax.io/platform/user-center/basic-information/interface-key
#   SiliconFlow — https://cloud.siliconflow.cn/account/ak
#   OpenRouter  — https://openrouter.ai/keys
DEEPSEEK_API_KEY=<set via setup-windows-env.ps1>
GROQ_API_KEY=<set via setup-windows-env.ps1>
MINIMAX_API_KEY=<set via setup-windows-env.ps1>
SILICONFLOW_API_KEY=<set via setup-windows-env.ps1>
OPENROUTER_API_KEY=<set via setup-windows-env.ps1>

# ── WebUI / Agent Token ───────────────────────────────────────────────────
WEBUI_AGENT_TOKEN=<set via setup-windows-env.ps1>
WEBUI_SECRET_KEY=<set via setup-windows-env.ps1>

# ── KiloCode Runtime ─────────────────────────────────────────────────────
KILOCODE_MODE=
LOG_LEVEL=

# ── Open WebUI ────────────────────────────────────────────────────────────
OPEN_WEBUI_SECRET_KEY=<set via setup-windows-env.ps1>

# ── VPS ──────────────────────────────────────────────────────────────────
VPS_HOST=<set via setup-windows-env.ps1>
VPS_USER=<set via setup-windows-env.ps1>
SSH_KEY=<set via setup-windows-env.ps1>

# ── Shiba Memory Gateway ─────────────────────────────────────────────────
SHIBA_URL=
SHIBA_DB_URL=<set via setup-windows-env.ps1>

# ── Hermes Bridge Auth ───────────────────────────────────────────────────
HERMES_API_KEY=<set via setup-windows-env.ps1>
HERMES_MINIMAX_API_KEY=<set via setup-windows-env.ps1>

# ── OpenClaw Gateway ─────────────────────────────────────────────────────
OPENCLAW_URL=http://localhost:18789

# ── ZeroClaw ─────────────────────────────────────────────────────────────
# ZeroClaw reads provider keys directly from process.env — no separate key.

# ── Discord (Hermes bots) ─────────────────────────────────────────────────
# DISCORD_TOKEN_HERMES1=<set via setup-windows-env.ps1>
# DISCORD_TOKEN_HERMES2=<set via setup-windows-env.ps1>
# DISCORD_TOKEN_HERMES3=<set via setup-windows-env.ps1>
# DISCORD_TOKEN_HERMES4=<set via setup-windows-env.ps1>
# DISCORD_TOKEN_HERMES5=<set via setup-windows-env.ps1>
# DISCORD_GUILD_ID=<set via setup-windows-env.ps1>
