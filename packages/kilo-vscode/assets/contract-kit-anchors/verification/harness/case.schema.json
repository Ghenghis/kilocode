{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://kilo.code/contract-kit/verification-case.schema.json",
	"title": "Verification Case",
	"description": "SWE-bench-style executable verification case. Maps a user story or requirement to a concrete test that produces evidence on failure.",
	"type": "object",
	"required": ["id", "title", "given", "when", "then", "run"],
	"additionalProperties": false,
	"properties": {
		"id": {
			"type": "string",
			"description": "Stable, human-readable identifier (e.g. CASE-AUTH-001).",
			"pattern": "^[A-Z][A-Z0-9-]{2,}$"
		},
		"title": {
			"type": "string",
			"minLength": 4
		},
		"given": {
			"type": "string",
			"description": "Pre-conditions (Gherkin Given clause)."
		},
		"when": {
			"type": "string",
			"description": "Action under test (Gherkin When clause)."
		},
		"then": {
			"type": "string",
			"description": "Expected outcome (Gherkin Then clause)."
		},
		"run": {
			"type": "object",
			"required": ["kind", "spec"],
			"additionalProperties": false,
			"properties": {
				"kind": {
					"type": "string",
					"enum": ["vitest", "playwright", "pytest", "cargo", "shell"],
					"description": "Test runner that should execute this case."
				},
				"spec": {
					"type": "string",
					"description": "Path to the spec file (relative to project root) or shell command to execute."
				},
				"evidencePaths": {
					"type": "array",
					"description": "Globs/paths to upload as forensic evidence on failure (traces, screenshots, logs).",
					"items": { "type": "string" },
					"default": []
				}
			}
		},
		"mapsTo": {
			"type": "object",
			"description": "Reverse-mapping back to PRD identifiers so coverage gates can check correspondence.",
			"additionalProperties": false,
			"properties": {
				"reqId": {
					"type": "string",
					"description": "Functional requirement id (e.g. F-3)."
				},
				"storyId": {
					"type": "string",
					"description": "User-story id (e.g. 1.1, 2.3)."
				}
			}
		}
	}
}
